# Frontend (Vite) - these are exposed to the browser
# Copy values from Firebase Console -> Project Settings -> Your apps -> Web app

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Public VAPID key - also exposed to the browser for push subscription
# Generate with: npm run generate-vapid
VITE_VAPID_PUBLIC_KEY=

# Backend (Vercel serverless) - NEVER expose these to the browser
# These go in Vercel Dashboard -> Project -> Settings -> Environment Variables

# VAPID keys (generate with: npm run generate-vapid)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Firebase Admin SDK (from Firebase Console -> Project Settings -> Service accounts)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
